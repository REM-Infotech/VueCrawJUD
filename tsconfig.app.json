{
  "compilerOptions": {
    "exclude": [
      "src/**/__tests__/*"
    ],
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "include": [
      "src/@types/env.d.ts",
      "src/**/*",
      "src/**/*.vue",
      "src/renderer/**/*.vue",
      "src/renderer/**/*",
      "src/@types"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@assets/*": [
        "./src/renderer/assets/*"
      ],
      "@components/*": [
        "./src/renderer/components/*"
      ],
      "@models/*": [
        "./src/models/*"
      ],
      "@pages/*": [
        "./src/renderer/pages/*"
      ],
      "@renderer": [
        "./src/renderer/*"
      ],
      "@routes/*": [
        "./src/renderer/pages/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@store/*": [
        "./src/stores/*"
      ],
      "@types/*": [
        "./src/@types/*"
      ]
    },
    "types": [
      "node",
      "app"
    ]
  }
}