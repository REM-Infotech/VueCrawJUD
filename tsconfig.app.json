{
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@assets/*": [
        "./src/renderer/assets/*"
      ],
      "@components/*": [
        "./src/renderer/components/*"
      ],
      "@models/*": [
        "./src/models/*"
      ],
      "@pages/*": [
        "./src/renderer/pages/*"
      ],
      "@renderer": [
        "./src/renderer/*"
      ],
      "@routes/*": [
        "./src/renderer/pages/*"
      ],
      "@shared/*": [
        "./src/shared/*"
      ],
      "@store/*": [
        "./src/stores/*"
      ],
      "@types/*": [
        "./src/@types/*"
      ]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  },
  "exclude": [
    "src/**/__tests__/*"
  ],
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "env.d.ts",
    "src/**/*",
    "src/**/*.vue"
  ]
}