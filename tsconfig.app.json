{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "typeRoots": ["./node_modules/@types", "src/@types"],
    "types": ["node", "app"]
  },
  "exclude": ["src/**/__tests__/*"],
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "src/@types/env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "src/renderer/**/*.vue",
    "src/renderer/**/*",
    "src/@types"
  ]
}
