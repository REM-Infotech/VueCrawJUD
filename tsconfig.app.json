{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": [
    "src/@types/env.d.ts",
    "src/**/*",
    "src/**/*.vue",
    "src/@types"
  ],
  "exclude": [
    "src/**/__tests__/*"
  ],
  "compilerOptions": {
    "typeRoots": [
      "./node_modules/@types",
      "src/@types"
    ],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@plugins/*": [
        "./src/plugins/*"
      ],
      "@routes/*": [
        "./src/pages/*"
      ],
    },
    "types": [
      "node",
      "app"
    ]
  }
}
